{
  "name": "chat-screeenshot",
  "displayName": "Chat Screeenshot",
  "description": "Turn copied chat replies into polished PNG screenshots and copy them to the clipboard.",
  "version": "0.0.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.113.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "codex",
    "chat",
    "screenshot",
    "clipboard",
    "png"
  ],
  "activationEvents": [
    "onCommand:codexChatScreenshot.openCollector"
  ],
  "main": "./src/extension.js",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "commands": [
      {
        "command": "codexChatScreenshot.openCollector",
        "title": "Open Collector",
        "category": "Chat Screeenshot"
      }
    ],
    "keybindings": [
      {
        "command": "codexChatScreenshot.openCollector",
        "key": "ctrl+alt+shift+s",
        "mac": "cmd+alt+shift+s"
      }
    ],
    "configuration": {
      "title": "Chat Screeenshot",
      "properties": {
        "codexChatScreenshot.clipboardPollIntervalMs": {
          "type": "number",
          "default": 800,
          "minimum": 250,
          "description": "How often the collector polls the system clipboard for newly copied chat content."
        },
        "codexChatScreenshot.ignoreInitialClipboardOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "When opening the collector, ignore whatever text is already on the clipboard until the user copies something new."
        }
      }
    }
  },
  "scripts": {
    "lint": "node --check src/extension.js && node --check media/preview.js",
    "test": "npm run lint"
  }
}
